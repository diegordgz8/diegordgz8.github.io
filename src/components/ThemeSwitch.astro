---
import { Icon } from 'astro-icon/components';
---

<button
    type="button"
    role="switch"
    aria-label="Cambiar tema"
    class="dark-toggle bg-surface-300 relative inline-flex h-10 w-18 cursor-pointer items-center rounded-full transition-colors duration-300 dark:bg-teal-700"
>
    <span
        class="bg-primary-500 absolute left-1.5 flex h-7 w-7 items-center justify-center rounded-full transition-transform duration-300 dark:translate-x-7 dark:bg-white"
    >
        <Icon name="mdi:white-balance-sunny" class="h-5 w-5 text-yellow-500 dark:hidden" />
        <Icon name="mdi:weather-night" class="hidden h-5 w-5 text-teal-700 dark:block" />
    </span>
</button>

<script>
    const setupTheme = () => {
        document.querySelectorAll('.dark-toggle').forEach((toggle) => {
            toggle.addEventListener('click', () => {
                const isDark = document.documentElement.classList.toggle('dark');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
        });
    };

    setupTheme();
    document.addEventListener('astro:after-swap', setupTheme);
</script>
