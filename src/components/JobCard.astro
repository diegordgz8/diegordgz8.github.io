---
import Image from 'astro/components/Image.astro';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';

interface Props {
    name: string;
    position: string;
    dateFrom: string;
    dateTo?: string;
    description: string;
    stack: string[];
    cover?: ImageMetadata;
}

const { name, position, dateFrom, dateTo, description, stack, cover } = Astro.props;
---

<article
    class="flex flex-col items-center gap-4 transition-transform duration-500 md:flex-row md:items-start lg:gap-8 lg:hover:translate-x-4"
>
    {
        cover && (
            <Image
                class="bg-surface-500 aspect-4/3 w-50 rounded-xl object-contain object-center p-4 sm:w-75 md:w-37.5 lg:w-50"
                src={cover}
                alt={name}
            />
        )
    }

    <div class="relative flex flex-col items-center overflow-hidden md:items-start">
        <span class="text-center text-2xl md:text-left">{name}</span>
        <h2
            class="text-primary-500 text-center text-2xl font-bold sm:text-3xl md:text-left lg:text-4xl dark:text-teal-500"
        >
            {position}
        </h2>
        <div class="mt-4 flex items-center">
            <Icon
                name="mdi:calendar-range"
                class="text-primary-500 mr-2 h-5 w-5 dark:text-teal-500"
            />
            <span class="text-center md:text-left">{dateFrom} - {dateTo}</span>
        </div>
        <div class="mt-4 flex flex-wrap gap-2 font-bold">
            {
                stack.map((item) => (
                    <span class="bg-muted-500 rounded-full px-3 py-1 text-sm text-white md:px-4">
                        {item}
                    </span>
                ))
            }
        </div>
        <p class="mt-4 opacity-70">{description}</p>
    </div>
</article>
