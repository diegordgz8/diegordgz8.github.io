---
interface Props {
    href: string;
    label: string;
}

const { href, label } = Astro.props;
---

<a
    class="nav-link hover:text-brand dark:hover:text-brand-dark w-full border-b-2 border-transparent pb-1 transition-all duration-300 [&.active]:border-brand dark:[&.active]:border-brand-dark"
    href={href}
    data-section={href.replace('/#', '')}
>
    {label}
</a>
