---
import MobileMenu from './MobileMenu.astro';
import NavLink from './NavLink.astro';
import ThemeSwitch from './ThemeSwitch.astro';
---

<header class="sticky top-0 z-50 w-full">
    <div
        id="header-bar"
        class="bg-primary-500/90 text-surface-500 flex h-24 items-center justify-end px-4 shadow-lg backdrop-blur-sm transition-all duration-500 lg:justify-between"
    >
        <a href="/#hero" class="mr-auto lg:mr-0" aria-label="Inicio">
            <svg id="header-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" class="h-20 w-20 transition-all duration-500">
                <defs>
                    <clipPath id="header-iris">
                        <circle cx="64" cy="64" r="60"/>
                    </clipPath>
                    <radialGradient id="headerIrisGrad" cx="50%" cy="45%" r="50%">
                        <stop offset="0%" stop-color="#d1d1d1"/>
                        <stop offset="100%" stop-color="#9a9a9a"/>
                    </radialGradient>
                </defs>
                <circle cx="64" cy="64" r="63" fill="#e8e8e8"/>
                <circle cx="64" cy="64" r="60" fill="url(#headerIrisGrad)"/>
                <polygon points="30,127 98,127 64,64" fill="#bfbfbf" clip-path="url(#header-iris)"/>
                <circle cx="64" cy="64" r="22" fill="#e8e8e8"/>
                <circle cx="50" cy="48" r="8" fill="white" opacity="0.7"/>
                <circle cx="76" cy="78" r="4" fill="white" opacity="0.3"/>
            </svg>
        </a>

        <nav
            class="hidden w-full flex-col items-center justify-center gap-8 text-xl font-semibold uppercase lg:flex lg:h-full lg:w-auto lg:flex-row"
        >
            <NavLink href="/#hero" label="Inicio" />
            <NavLink href="/#jobs" label="Experiencia" />
            <NavLink href="/#portfolio" label="Proyectos" />
            <NavLink href="/#skills" label="Habilidades" />
            <NavLink href="/#contact" label="Contacto" />
        </nav>

        <div class="hidden lg:block">
            <ThemeSwitch />
        </div>

        <MobileMenu />
    </div>
</header>

<script>
    // Active nav link based on visible section
    const setupNavObserver = () => {
        const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link');
        const sections = document.querySelectorAll<HTMLElement>('section[id]');

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        navLinks.forEach((link) => {
                            const isActive = link.dataset.section === entry.target.id;
                            link.classList.toggle('active', isActive);
                        });
                    }
                });
            },
            { rootMargin: '-20% 0px -70% 0px' },
        );

        sections.forEach((section) => observer.observe(section));
    };

    const setupLogoResize = () => {
        const logo = document.getElementById('header-logo');
        const bar = document.getElementById('header-bar');
        if (!logo || !bar) return;

        const update = () => {
            const scrolled = window.scrollY > 10;
            logo.classList.toggle('h-14', scrolled);
            logo.classList.toggle('w-14', scrolled);
            logo.classList.toggle('h-20', !scrolled);
            logo.classList.toggle('w-20', !scrolled);
            bar.classList.toggle('h-24', scrolled);
            bar.classList.toggle('h-28', !scrolled);
        };

        update();
        window.addEventListener('scroll', update, { passive: true });
    };

    setupNavObserver();
    setupLogoResize();
    document.addEventListener('astro:after-swap', () => {
        setupNavObserver();
        setupLogoResize();
    });
</script>
