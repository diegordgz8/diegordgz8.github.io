---
import { Icon } from 'astro-icon/components';
import NavLink from './NavLink.astro';
import ThemeSwitch from './ThemeSwitch.astro';
---

<div
    id="mobile-menu"
    class="bg-primary-500/95 text-surface-500 pointer-events-none fixed inset-0 left-auto z-50 flex h-dvh w-full max-w-80 translate-x-full flex-col items-end justify-between gap-8 p-8 pt-24 text-xl font-semibold uppercase opacity-0 backdrop-blur-sm transition-all duration-300 lg:hidden"
>
    <button
        id="mobile-menu-close"
        type="button"
        aria-label="Cerrar menú"
        class="absolute top-6 right-6 cursor-pointer"
    >
        <Icon name="mdi:close" class="h-8 w-8" />
    </button>

    <nav class="flex flex-col items-end gap-8 text-right">
        <NavLink href="/#hero" label="Inicio" />
        <NavLink href="/#jobs" label="Experiencia" />
        <NavLink href="/#portfolio" label="Proyectos" />
        <NavLink href="/#skills" label="Habilidades" />
        <NavLink href="/#contact" label="Contacto" />
    </nav>

    <div class="flex flex-col items-end gap-4">
        <div class="flex gap-4">
            <a href="https://wa.me/584245458256" target="_blank" aria-label="WhatsApp">
                <Icon name="mdi:whatsapp" class="h-8 w-8" />
            </a>
            <a href="https://github.com/diegordgz8" target="_blank" aria-label="GitHub">
                <Icon name="mdi:github" class="h-8 w-8" />
            </a>
            <a href="https://linkedin.com/in/diegordgz8" target="_blank" aria-label="LinkedIn">
                <Icon name="mdi:linkedin" class="h-8 w-8" />
            </a>
        </div>
        <ThemeSwitch />
    </div>
</div>

<script>
    const setupMobileMenu = () => {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        const closeBtn = document.getElementById('mobile-menu-close');
        if (!toggle || !menu || !closeBtn) return;

        const open = () => {
            menu.classList.remove('translate-x-full', 'opacity-0', 'pointer-events-none');
            menu.classList.add('translate-x-0', 'opacity-100', 'pointer-events-auto');
            document.body.classList.add('overflow-hidden');
        };

        const close = () => {
            menu.classList.add('translate-x-full', 'opacity-0', 'pointer-events-none');
            menu.classList.remove('translate-x-0', 'opacity-100', 'pointer-events-auto');
            document.body.classList.remove('overflow-hidden');
        };

        toggle.addEventListener('click', open);
        closeBtn.addEventListener('click', close);

        menu.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', close);
        });
    };

    setupMobileMenu();
    document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
