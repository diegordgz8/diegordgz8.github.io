---
import { Icon } from 'astro-icon/components';
import NavLink from './NavLink.astro';
import ThemeSwitch from './ThemeSwitch.astro';
---

<button
    id="mobile-menu-toggle"
    type="button"
    aria-label="Abrir menú"
    class="text-surface-500 relative z-60 cursor-pointer lg:hidden"
>
    <Icon id="menu-open-icon" name="mdi:menu" class="h-8 w-8" />
    <Icon id="menu-close-icon" name="mdi:close" class="hidden h-8 w-8" />
</button>

<div
    id="mobile-menu"
    class="bg-primary-500/95 text-surface-500 fixed inset-0 left-auto z-50 flex h-dvh w-full max-w-80 translate-x-full flex-col items-end justify-between gap-8 p-8 pt-24 text-xl font-semibold uppercase backdrop-blur-sm transition-transform duration-300 lg:hidden"
>
    <nav class="flex flex-col items-end gap-8 text-right">
        <NavLink href="/#hero" label="Inicio" />
        <NavLink href="/#jobs" label="Experiencia" />
        <NavLink href="/#portfolio" label="Proyectos" />
        <NavLink href="/#skills" label="Habilidades" />
        <NavLink href="/#contact" label="Contacto" />
    </nav>

    <div class="flex flex-col items-end gap-4">
        <div class="flex gap-4">
            <a href="https://wa.me/584245458256" target="_blank" aria-label="WhatsApp">
                <Icon name="mdi:whatsapp" class="h-8 w-8" />
            </a>
            <a href="https://github.com/diegordgz8" target="_blank" aria-label="GitHub">
                <Icon name="mdi:github" class="h-8 w-8" />
            </a>
            <a href="https://linkedin.com/in/diegordgz8" target="_blank" aria-label="LinkedIn">
                <Icon name="mdi:linkedin" class="h-8 w-8" />
            </a>
        </div>
        <ThemeSwitch />
    </div>
</div>

<script>
    const setupMobileMenu = () => {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        const openIcon = document.getElementById('menu-open-icon');
        const closeIcon = document.getElementById('menu-close-icon');
        if (!toggle || !menu || !openIcon || !closeIcon) return;

        const close = () => {
            menu.classList.add('translate-x-full');
            menu.classList.remove('translate-x-0');
            openIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        };

        toggle.addEventListener('click', () => {
            const isOpen = menu.classList.contains('translate-x-0');
            if (isOpen) {
                close();
            } else {
                menu.classList.remove('translate-x-full');
                menu.classList.add('translate-x-0');
                openIcon.classList.add('hidden');
                closeIcon.classList.remove('hidden');
                document.body.classList.add('overflow-hidden');
            }
        });

        menu.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', close);
        });
    };

    setupMobileMenu();
    document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
